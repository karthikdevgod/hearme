# ───────────────────────────────────────────────────────────────────
# HearMe — environment configuration (single source of truth)
# Copy to .env and fill in. Validated by packages/config at startup.
# Nothing in the product is hardcoded — every limit/price/flag lives here.
# ───────────────────────────────────────────────────────────────────

# ── App ──
NODE_ENV=development
APP_NAME=HearMe
# Public URLs
NEXT_PUBLIC_APP_NAME=HearMe
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
API_PORT=4000

# ── Free tier / trial ──
FREE_MINUTES_PER_DAY=10
FREE_TRIAL_DAYS=6

# ── Monetization toggles ──
ENABLE_PAYG=true
ENABLE_SUBSCRIPTIONS=true
PAYG_PRICE_PER_MINUTE=0.10
CREDITS_PER_MINUTE=1

# ── Subscription plans (seeded into Firestore `plans`) ──
BASIC_PLAN_PRICE=9.99
BASIC_PLAN_MINUTES=300
PRO_PLAN_PRICE=19.99
PRO_PLAN_MINUTES=999999

# ── PAYG credit packs (USD) ──
CREDIT_PACKS=5,10,20

# ── Feature flags ──
ENABLE_MEMORY=true
ENABLE_REPORTS=true
ENABLE_MOOD_ANALYSIS=true
ENABLE_AUDIO_STORAGE=true
ENABLE_PHONE_LOGIN=false
ENABLE_EMAIL_LOGIN=true
ENABLE_GOOGLE_LOGIN=true

# ── Supported conversation languages (dynamic, comma-separated) ──
SUPPORTED_LANGUAGES=en,hi,hinglish,de,es,fr,ar,pt,ja
DEFAULT_LANGUAGE=en

# ── Retention ──
AUDIO_RETENTION_DAYS=30

# ── OpenAI ──
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_STT_MODEL=gpt-4o-transcribe
# Cost metering (USD) — used to compute llmCost/sttCost
OPENAI_LLM_INPUT_COST_PER_1M=2.50
OPENAI_LLM_OUTPUT_COST_PER_1M=10.00
OPENAI_STT_COST_PER_MINUTE=0.006

# ── ElevenLabs ──
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_TTS_COST_PER_1K_CHARS=0.30

# ── Stripe ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Firebase (Admin SDK — api) ──
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# ── Firebase (client SDK — web, all public) ──
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Emulators (local dev) ──
FIREBASE_AUTH_EMULATOR_HOST=
FIRESTORE_EMULATOR_HOST=
FIREBASE_STORAGE_EMULATOR_HOST=

# ── Analytics / Monitoring ──
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── Security ──
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=120
CORS_ORIGINS=http://localhost:3000
